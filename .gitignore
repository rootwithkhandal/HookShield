# =============================================================================
# LogDefender — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Secrets & credentials — NEVER commit these
# -----------------------------------------------------------------------------
.env
.config
config.local.yaml          # local overrides with real credentials

# config.yaml is committed as an empty template (all values are blank).
# If you add real credentials to it, add it here:
# config.yaml

# -----------------------------------------------------------------------------
# Runtime artifacts
# -----------------------------------------------------------------------------
*.log
*.db
*.sqlite3

# Quarantine folder and its manifest sidecars
quarantine/
*.quar
*.quar.manifest

# -----------------------------------------------------------------------------
# Python bytecode & caches
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# -----------------------------------------------------------------------------
# Virtual environments
# -----------------------------------------------------------------------------
.venv/
venv/
env/
ENV/
.virtualenv/

# -----------------------------------------------------------------------------
# Build & packaging
# -----------------------------------------------------------------------------
dist/
build/
*.egg-info/
*.egg
MANIFEST
*.spec                     # PyInstaller spec files (auto-generated)

# PyInstaller output
/dist/
/build/

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.tox/

# -----------------------------------------------------------------------------
# IDE & editor files
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# OS generated
# -----------------------------------------------------------------------------
desktop.ini
$RECYCLE.BIN/
