# Copy this file to .config and fill in your real values.
# .config is listed in .gitignore and will NOT be committed.

VIRUS_TOTAL_API_KEY=your_virustotal_api_key_here

EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECEIVER=admin-email@gmail.com

# SIEM / Syslog Export
OUTPUT_MODE=both
SYSLOG_HOST=127.0.0.2
SYSLOG_PORT=514

# Threat Intel Feeds (Live CTI)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here
MALWARE_BAZAAR_API_KEY=your_malware_bazaar_api_key_here
